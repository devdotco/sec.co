// SEC.co enrichment data model (proposed) — Postgres via Prisma.
// Layers kept separate: RAW → NORMALIZED → ENRICHED → PUBLISHED. Embeddings live
// in Qdrant (dedicated instance), NOT here. Provenance stamped on every source row.
// This is a proposal for review — not yet applied.

generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

// ── RAW (verbatim source, audit/replay) ─────────────────────────────────────
model RawSource {
  id          BigInt   @id @default(autoincrement())
  sourceType  String   // 'nvd_cve' | 'nvd_cpe' | 'cisa_kev' | 'osv' | 'epss'
  sourceKey   String   // e.g. CVE-2021-44228
  payload     Json     // verbatim
  contentHash String   // gates re-normalize/re-enrich
  license     String   // 'public-domain' | 'cc-by-4.0' | ...
  sourceUrl   String
  retrievedAt DateTime @default(now())
  @@unique([sourceType, sourceKey])
  @@index([contentHash])
}

// ── NORMALIZED ───────────────────────────────────────────────────────────────
model CveRecord {
  cveId          String   @id                  // CVE-2021-44228
  description    String                        // source (public domain)
  cvssScore      Float?
  cvssSeverity   String?                       // CRITICAL|HIGH|MEDIUM|LOW
  cvssVector     String?
  cvssVersion    String?                       // 3.1|3.0|2.0
  published      DateTime?
  lastModified   DateTime?
  refCount       Int      @default(0)
  isKev          Boolean  @default(false)
  epssScore      Float?
  contentHash    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  weaknesses     CveWeakness[]
  affected       VulnAffectedProduct[]
  references     CveReference[]
  kev            KevRecord?
  enrichment     EnrichmentOutput?
  page           PublishedPage?
  @@index([cvssSeverity]); @@index([isKev]); @@index([published])
}

model CveReference { id BigInt @id @default(autoincrement()); cveId String; url String; tags String[]; cve CveRecord @relation(fields:[cveId],references:[cveId]); @@index([cveId]) }
model CveWeakness  { id BigInt @id @default(autoincrement()); cveId String; cweId String; cve CveRecord @relation(fields:[cveId],references:[cveId]); @@unique([cveId,cweId]); @@index([cweId]) }

model Vendor  { id BigInt @id @default(autoincrement()); slug String @unique; name String; normalizedName String; products Product[]; @@index([normalizedName]) }
model Product { id BigInt @id @default(autoincrement()); vendorId BigInt; slug String; name String; vendor Vendor @relation(fields:[vendorId],references:[id]); versions ProductVersion[]; @@unique([vendorId,slug]) }
model ProductVersion { id BigInt @id @default(autoincrement()); productId BigInt; version String; cpe23 String; product Product @relation(fields:[productId],references:[id]); @@index([cpe23]) }

model VulnAffectedProduct {
  id BigInt @id @default(autoincrement())
  cveId String; cpe23 String; vendor String; product String
  versionStartIncluding String?; versionEndExcluding String?
  cve CveRecord @relation(fields:[cveId],references:[cveId])
  @@index([cveId]); @@index([vendor, product])
}

model CpeRecord { id BigInt @id @default(autoincrement()); cpe23 String @unique; vendor String; product String; targetSw String?; deprecated Boolean @default(false); @@index([vendor,product]) }

model KevRecord {
  cveId String @id
  vendorProject String; product String; vulnerabilityName String
  dateAdded DateTime; dueDate DateTime?
  requiredAction String; shortDescription String
  knownRansomwareCampaignUse String?          // 'Known' | 'Unknown'
  cve CveRecord @relation(fields:[cveId],references:[cveId])
}

model OsvRecord    { id String @id; ecosystem String; packageName String; summary String; details String; license String; sourceUrl String; modified DateTime; contentHash String; @@index([ecosystem, packageName]) }
model CweRecord    { cweId String @id; name String; description String; publishable Boolean @default(true) }
model CapecRecord  { capecId String @id; name String; description String }

// ── ENRICHED (our original derivative content; versioned by prompt) ───────────
model EnrichmentOutput {
  id            BigInt   @id @default(autoincrement())
  cveId         String   @unique
  promptVersion String
  model         String                          // claude-haiku-4-5 | claude-sonnet-5
  data          Json                            // matches sec-enrichment.schema.json
  wordCount     Int
  inputTokens   Int
  outputTokens  Int
  costUsd       Float
  status        String   @default("generated")  // generated|reviewed|rejected
  createdAt     DateTime @default(now())
  cve           CveRecord @relation(fields:[cveId],references:[cveId])
  @@index([status]); @@index([promptVersion])
}

// ── PUBLISHED / SEO / LINK GRAPH ─────────────────────────────────────────────
model PublishedPage {
  id           BigInt   @id @default(autoincrement())
  pageType     String                           // cve|vendor|product|cwe|glossary|hub
  cveId        String?  @unique
  canonicalUrl String   @unique
  slug         String
  indexState   String   @default("noindex")     // index|noindex|review
  qualityScore Float?
  seoTitle     String?
  seoDescription String?
  schemaJsonld Json?
  lastUpdated  DateTime @updatedAt
  publishedAt  DateTime?
  cve          CveRecord? @relation(fields:[cveId],references:[cveId])
  @@index([pageType]); @@index([indexState]); @@index([qualityScore])
}

model InternalLink  { id BigInt @id @default(autoincrement()); fromUrl String; toUrl String; anchor String; kind String; @@index([fromUrl]); @@unique([fromUrl,toUrl]) }
model SitemapEntry  { id BigInt @id @default(autoincrement()); url String @unique; segment String; lastmod DateTime; priority Float?; includedAt DateTime @default(now()); @@index([segment]) }

// ── OPS: sync / cost / quality ───────────────────────────────────────────────
model SourceSyncRun   { id BigInt @id @default(autoincrement()); sourceType String; startedAt DateTime @default(now()); finishedAt DateTime?; fetched Int @default(0); upserted Int @default(0); changed Int @default(0); ok Boolean @default(false); @@index([sourceType]) }
model SourceSyncError { id BigInt @id @default(autoincrement()); sourceType String; sourceKey String?; message String; payload Json?; createdAt DateTime @default(now()); @@index([sourceType]) }
model AiCostLog        { id BigInt @id @default(autoincrement()); cveId String?; model String; kind String; inputTokens Int; outputTokens Int; costUsd Float; batch Boolean @default(false); createdAt DateTime @default(now()); @@index([createdAt]) }
model EmbeddingCostLog { id BigInt @id @default(autoincrement()); cveId String?; model String @default("bge-small-en-v1.5"); vectors Int; createdAt DateTime @default(now()) }
model PageQualityScore { id BigInt @id @default(autoincrement()); cveId String @unique; score Float; sourceCompleteness Float; enrichmentRichness Float; signal Float; computedAt DateTime @default(now()); @@index([score]) }
