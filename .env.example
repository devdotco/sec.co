# ─── Resend transactional email ──────────────────────────────────────────────
# Required for /api/contact (contact form submissions).

# API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Sender (must be on a verified Resend sending domain).
# Until sec.co is verified in Resend, you can use the onboarding sender
# "onboarding@resend.dev" for testing.
CONTACT_FROM_EMAIL=noreply@sec.co

# Recipient — where the team gets notified about new submissions.
CONTACT_TO_EMAIL=team@sec.co

# Optional: additional BCC recipients (comma-separated).
# CONTACT_BCC=

# Optional: send a confirmation email back to the submitter.
# CONFIRMATION_ENABLED=true

# ─── Vulnerability intelligence pipeline (Phase 1) ───────────────────────────
# Anthropic key for Haiku 4.5 enrichment (scripts/vuln/enrich.ts).
# ENRICHMENT_ANTHROPIC_API_KEY takes precedence over ANTHROPIC_API_KEY.
# Recommend a SEC.co-specific key for clean cost attribution.
ENRICHMENT_ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional free NVD API key — raises ingest rate limit ~5→~50 req/30s.
# Get one at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# Production storage (Phase 3+): swap the file-backed store for Postgres.
# See docs/sec-schema.prisma. Not used by the Phase 1 file store.
# DATABASE_URL=postgresql://user:pass@localhost:5432/sec?schema=public
